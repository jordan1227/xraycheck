# Локальная конфигурация и результат проверки
.env

# Текстовые файлы (кроме README.md)
*.txt
!requirements.txt
*.md
!README.md

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
.eggs/

# Xray (автоустановка скриптом при запуске)
xray_dist/
xray-dist/

# Временные и системные
*.log
.DS_Store
Thumbs.db

# Метрики и аналитика
metrics.json
metrics_*.json
*_metrics.json

# Кэш результатов проверки
.checker_cache.json
checker_cache.json

# Экспорт результатов
exports/
# HTML экспорт результатов проверки
available*.html
# CSV экспорт результатов проверки
available*.csv
# JSON экспорт результатов проверки (кроме метрик)
available*.json
# Частичные результаты при прерывании
*_partial.txt

# Результаты проверки в корне проекта (игнорируем файлы в корне)
/available*.txt
/white-list_available*.txt
# Исключения для директории configs/ и файлов в ней (должны быть отслежены в git)
!configs/
!configs/available.txt
!configs/available(top100).txt
!configs/white-list_available.txt
!configs/white-list_available(top100).txt
github_parser/